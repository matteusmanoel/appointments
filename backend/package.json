{
  "name": "barber-harmony-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "migrate": "node --experimental-vm-modules node_modules/.bin/db-migrate",
    "seed": "node dist/scripts/seed.js",
    "seed:dev": "tsx src/scripts/seed.ts",
    "seed:demo": "node dist/scripts/seed-demo.js",
    "seed:demo:dev": "tsx src/scripts/seed-demo.ts",
    "tools:create-api-key": "tsx src/scripts/create-api-key.ts"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.700.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.0",
    "serverless-http": "^3.2.0",
    "stripe": "^17.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
